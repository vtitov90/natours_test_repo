extends base

include _noEntries

block content
  main.main
    if tours && tours.length > 0
      .card-container
        each tour in tours
          .card
            .card__header
              .card__picture
                .card__picture-overlay &nbsp;
                img.card__picture-img(src=`/img/tours/${tour.imageCover}`, alt=`${tour.name}`)
              h3.heading-tertirary
                span= tour.name
            .card__details
              h4.card__sub-heading= `${tour.difficulty} ${tour.duration}-day tour`
              if tour.isMyBooking
                p.card__text= tour.summary
                .card__data
                  svg.card__icon
                    use(xlink:href='/img/icons.svg#icon-map-pin')
                  span= tour.startLocation.description
                .card__data
                  svg.card__icon
                    use(xlink:href='/img/icons.svg#icon-calendar')
                  span= tour.startDates[0].toLocaleString('en-us', {month: 'long', year: 'numeric'})
                .card__data
                  svg.card__icon
                    use(xlink:href='/img/icons.svg#icon-flag')
                  span= `${tour.locations.length} stops`
                .card__data
                  svg.card__icon
                    use(xlink:href='/img/icons.svg#icon-user')
                  span= `${tour.maxGroupSize} people`
              else
                .card__data
                  svg.card__icon
                    use(xlink:href='/img/icons.svg#icon-map-pin')
                  span= tour.startLocation.description
                .card__data
                  svg.card__icon
                    use(xlink:href='/img/icons.svg#icon-calendar')
                  span= tour.startDates[0].toLocaleString('en-us', {month: 'long', year: 'numeric'})
            if !tour.isMyBooking
              .book__info
                p= `Booked by ${tour.user.name}`
                img.book__img(src=`/img/users/${tour.user.photo}`)

            .card__footer_booking
              a.btn.btn--green.btn--small.btn__booking(href=tour.isMyBooking ? (tour.hasReview ? `/reviews/${tour.reviewId}/edit` : `/reviews/new/${tour._id}`) : `/bookings/${tour.bookingId}/edit`)= tour.isMyBooking ? "Review" : "Edit"

              p.card__footer-value= `$ ${tour.price}/pers`
              a#cancel.btn.btn--green.btn--small.btn__booking(href="#" data-booking-id=`${tour.bookingId}`) Cancel
      
    
      if tours.some(tour => !tour.isMyBooking)
        .add-booking-container
          a.btn-add-booking(href="/bookings/new") 
            svg.btn-add-booking__icon
              use(xlink:href='/img/icons.svg#icon-plus')
    else
      +noEntries(
        "You haven't booked any tours yet",
        'Explore our exciting tours and book your next adventure!',
        'Explore Tours',
        '/'
      )